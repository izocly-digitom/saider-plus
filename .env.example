# Copier ce fichier en .env puis renseigner les valeurs locales.
# .env est gitignoré ; ce fichier .env.example est versionné comme référence.

# Port du serveur Express
PORT=3000

# Serveur SMTP (Gmail, OVH, Mailjet, etc.)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
# true seulement si port 465 (TLS implicite). Sinon laisser false (STARTTLS).
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Adresse de réception des messages du formulaire de contact
CONTACT_TO=
# Adresse d'expéditeur (From). Si vide, SMTP_USER est utilisé.
CONTACT_FROM=
